# Website
NEXT_PUBLIC_SITE_URL=https://your-vercel-domain.vercel.app

# Email bot security
# Use a long random value. Manual calls must send:
# Authorization: Bearer <EMAIL_BOT_SECRET>
EMAIL_BOT_SECRET=

# Gmail OAuth
# Create these in Google Cloud OAuth credentials.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Optional AI generation with Gemini. If missing, the bot uses the safe built-in template.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Bot behavior
EMAIL_BOT_MODE=draft
EMAIL_BOT_MAX_MESSAGES=5
EMAIL_BOT_LOOKBACK_DAYS=14
EMAIL_BOT_NOTIFY_EMAIL=
